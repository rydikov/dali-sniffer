menu "Example Configuration"

    config WIFI_SSID
        string "Wi-Fi SSID"
        default ""
        help
            Wi-Fi network name for the station connection.

    config WIFI_PASSWORD
        string "Wi-Fi password"
        default ""
        help
            Wi-Fi password for the station connection.

    config LOG_PERIOD_MS
        int "Log period in ms"
        range 10 3600000
        default 5000
        help
            Legacy log period setting from the previous heartbeat example.

endmenu
